{
    "name": "social-poster/app",
    "description": "AI-powered daily Facebook and LinkedIn posting system",
    "type": "project",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.14"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "setup": "bash bin/setup.sh"
    },
    "config": {
        "sort-packages": true
    }
}
