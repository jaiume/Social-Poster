[app]
name = "Social-Poster"
debug = true
base_url = "https://socialposter.stuckbendix.com"
; Dev host URL for OpenRouter attribution.
openrouter_referer = "https://socialposter.stuckbendix.com"

[database]
driver = "mysql"
host = "localhost"
port = 3306
name = "social_poster"
user = "social_poster"
password = ""
charset = "utf8mb4"
; SQLite (local dev / tests only):
; driver = "sqlite"
; path = "../var/data/social_poster.sqlite"

[auth]
admin_username = "admin"
admin_password = ""

[logging]
path = "../var/logs"
level = "info"

[security]
session_name = "social_poster_session"
csrf_enabled = true
; Generate with: php -r "echo bin2hex(random_bytes(32));"
encryption_key = ""
