<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — {{ session.name }} — {{ app_name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; }
        #browser-view {
            width: 100%;
            max-width: 640px;
            cursor: crosshair;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            min-height: 200px;
        }
        #browser-view.loading { opacity: 0.5; }
        /* Capture works in a ~520px-wide popup; Bootstrap md (768px) is too strict. */
        #capture-too-narrow { display: none; }
        @media (max-width: 519.98px) {
            #capture-too-narrow { display: block; }
            #capture-desktop { display: none !important; }
        }
    </style>
</head>
<body class="p-3">
<div class="container" style="max-width: 680px;">
    <div id="capture-too-narrow" class="alert alert-warning">
        This window is too narrow for browser login. Widen it to at least 520px, or maximize the window and refresh.
    </div>

    <div id="capture-desktop">
    <h1 class="h5 mb-3">Log in — {{ session.name }}</h1>
    {% if session.platform == 'linkedin' %}
    <p class="small text-muted mb-2">LinkedIn 2FA: enter your authenticator code when prompted. When the feed looks right, click <strong>Save session</strong>.</p>
    {% elseif session.platform == 'facebook' %}
    <p class="small text-muted mb-2">After login, use the browser view to open <strong>Feeds</strong> (your personal home). Do not save while you are on a Page admin screen (Manage Page / Professional dashboard). When the feed looks right, click <strong>Save session</strong>.</p>
    {% endif %}
    <p id="status-text" class="text-muted small mb-2">Starting browser…</p>
    <div id="alert-box" class="alert d-none" role="alert"></div>

    <img id="browser-view" class="loading mb-3 d-none" alt="Browser view" title="Click to interact">

    <div id="type-panel" class="card card-body mb-3 d-none">
        <label class="form-label small mb-1">Type into the selected field</label>
        <div class="input-group input-group-sm">
            <input type="text" id="type-input" class="form-control" placeholder="Text to type" autocomplete="off">
            <button type="button" id="type-send" class="btn btn-secondary">Send</button>
            <button type="button" id="key-enter" class="btn btn-outline-secondary">Enter</button>
        </div>
        <div class="form-text">Click an input in the view above, then type here and press Send or Enter.</div>
    </div>

    <button type="button" id="save-btn" class="btn btn-success mb-2 d-none">Save session</button>
    <button type="button" id="close-btn" class="btn btn-primary d-none" onclick="finish()">Done — close window</button>
    </div>
</div>

<script>
const CAPTURE_MIN_WIDTH = 520;
const sessionId = {{ session.id|json_encode|raw }};
const csrfToken = {{ csrf_token|json_encode|raw }};
const VIEWPORT_W = 1280;
const VIEWPORT_H = 720;
let jobId = null;
let pollTimer = null;
let captureStarted = false;

function captureViewportOk() {
    return window.innerWidth >= CAPTURE_MIN_WIDTH;
}

function updateCaptureLayout() {
    const narrow = document.getElementById('capture-too-narrow');
    const desktop = document.getElementById('capture-desktop');
    if (captureViewportOk()) {
        narrow.style.display = 'none';
        desktop.style.display = 'block';
        return true;
    }
    narrow.style.display = 'block';
    desktop.style.display = 'none';
    return false;
}

function showAlert(message, type = 'danger') {
    const box = document.getElementById('alert-box');
    box.textContent = message;
    box.className = 'alert alert-' + type;
    box.classList.remove('d-none');
}

async function startCapture() {
    if (captureStarted || !captureViewportOk()) return;
    captureStarted = true;
    const res = await fetch('/sessions/capture/' + sessionId + '/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'csrf_token=' + encodeURIComponent(csrfToken),
    });
    const data = await res.json();
    if (!data.success) {
        captureStarted = false;
        showAlert(data.message || 'Failed to start capture.');
        document.getElementById('status-text').textContent = 'Could not start.';
        return;
    }
    jobId = data.data.jobId;
    document.getElementById('type-panel').classList.remove('d-none');
    pollTimer = setInterval(pollStatus, 800);
    pollStatus();
}

async function pollStatus() {
    if (!jobId) return;
    const res = await fetch('/sessions/capture/jobs/' + jobId + '/status');
    const data = await res.json();
    if (!data.success) {
        clearInterval(pollTimer);
        showAlert('Capture session lost.');
        return;
    }
    const info = data.data;
    document.getElementById('status-text').textContent = info.message || info.status;

    if (info.hasScreenshot) {
        const img = document.getElementById('browser-view');
        img.src = '/sessions/capture/jobs/' + jobId + '/screenshot?t=' + Date.now();
        img.classList.remove('d-none', 'loading');
    }

    if (info.status === 'ready') {
        document.getElementById('save-btn').classList.remove('d-none');
        document.getElementById('type-panel').classList.remove('d-none');
    }

    if (info.status === 'imported') {
        clearInterval(pollTimer);
        document.getElementById('save-btn').classList.add('d-none');
        showAlert('Session saved successfully.', 'success');
        document.getElementById('close-btn').classList.remove('d-none');
        if (window.opener) {
            window.opener.location.reload();
        }
    } else if (info.status === 'error') {
        clearInterval(pollTimer);
        showAlert(info.message || 'Capture failed.');
    }
}

async function sendCommand(payload) {
    if (!jobId) return;
    const body = new URLSearchParams({ csrf_token: csrfToken, ...payload });
    await fetch('/sessions/capture/jobs/' + jobId + '/command', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString(),
    });
}

document.getElementById('browser-view').addEventListener('click', async (e) => {
    const img = e.currentTarget;
    const rect = img.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * VIEWPORT_W;
    const y = ((e.clientY - rect.top) / rect.height) * VIEWPORT_H;
    img.classList.add('loading');
    await sendCommand({ action: 'click', x: String(x), y: String(y) });
    setTimeout(() => img.classList.remove('loading'), 300);
});

document.getElementById('type-send').addEventListener('click', async () => {
    const input = document.getElementById('type-input');
    const text = input.value;
    if (!text) return;
    await sendCommand({ action: 'type', text });
    input.value = '';
});

document.getElementById('type-input').addEventListener('keydown', async (e) => {
    if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('type-send').click();
    }
});

document.getElementById('key-enter').addEventListener('click', () => sendCommand({ action: 'key', key: 'Enter' }));

document.getElementById('save-btn').addEventListener('click', async () => {
    const btn = document.getElementById('save-btn');
    btn.disabled = true;
    document.getElementById('status-text').textContent = 'Saving session…';
    await sendCommand({ action: 'save' });
});

function finish() {
    window.close();
}

updateCaptureLayout();
startCapture();

window.addEventListener('resize', () => {
    updateCaptureLayout();
    startCapture();
});
</script>
</body>
</html>
