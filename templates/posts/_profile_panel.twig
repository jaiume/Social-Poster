<div class="workspace-panel profile-panel p-2">
    <div class="d-flex justify-content-between align-items-center mb-2 px-1">
        <span class="fw-semibold small text-uppercase text-muted">Profiles</span>
        <a href="/posts?new_profile=1" class="btn btn-sm btn-outline-primary" title="Add profile"><i class="bi bi-plus-lg"></i></a>
    </div>
    <div class="list-group list-group-flush">
        {% for p in profiles %}
        <div class="list-group-item profile-row py-2 {{ selected_profile_id == p.id ? 'active' : '' }}">
            <div class="d-flex align-items-center justify-content-between gap-1">
                <a href="/posts?profile={{ p.id }}" class="text-decoration-none text-body flex-grow-1 text-truncate">
                    {{ p.name }}
                    {% if not p.is_active %}<span class="badge text-bg-secondary ms-1">off</span>{% endif %}
                </a>
                <div class="text-nowrap">
                    <a href="/posts?profile={{ p.id }}&edit_profile={{ p.id }}" class="btn btn-link btn-sm p-0 text-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="/profiles/{{ p.id }}/delete" class="d-inline" onsubmit="return confirm('Delete profile {{ p.name|e('js') }}?');">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <button type="submit" class="btn btn-link btn-sm p-0 text-danger" title="Delete"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="list-group-item text-muted small">No profiles yet.</div>
        {% endfor %}
    </div>
</div>
