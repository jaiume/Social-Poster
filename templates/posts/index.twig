{% extends "layout_app.twig" %}

{% block title %}Posts — {{ app_name }}{% endblock %}

{% block body %}
{% if deleted %}<div class="alert alert-success">Post deleted.</div>{% endif %}
<h1 class="h3 mb-4">Post history</h1>
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead>
                <tr><th>ID</th><th>Profile</th><th>Status</th><th>Created</th><th></th></tr>
            </thead>
            <tbody>
                {% for post in posts %}
                {% set profile = profiles[post.product_profile_id]|default(null) %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>{{ profile.name|default(post.product_profile_id) }}</td>
                    <td>
                        {% if profile and profile.review_before_posting and post.status == 'ready' %}
                        <span class="badge text-bg-warning">awaiting review</span>
                        {% else %}
                        <span class="badge text-bg-secondary">{{ post.status }}</span>
                        {% endif %}
                    </td>
                    <td>{{ post.created_at }}</td>
                    <td class="text-nowrap">
                        <a href="/posts/{{ post.id }}">View</a>
                        {% if profile and profile.review_before_posting and post.status == 'ready' %}
                        <form method="post" action="/posts/{{ post.id }}/publish" class="d-inline ms-2"
                              onsubmit="return confirm('Publish post #{{ post.id }} now?');">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-primary">Publish</button>
                        </form>
                        {% endif %}
                        <form method="post" action="/posts/{{ post.id }}/delete" class="d-inline"
                              onsubmit="return confirm('Delete post #{{ post.id }}? This cannot be undone.');">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-link btn-sm text-danger p-0 ms-2">Delete</button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="text-muted">No posts yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
