{% extends "layout_app.twig" %}

{% block title %}Post #{{ post.id }} — {{ app_name }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">Post #{{ post.id }}</h1>
<p>Profile: {{ profile.name|default(post.product_profile_id) }} · Status: <span class="badge">{{ post.status }}</span></p>

{% if review_notice %}<div class="alert alert-info">Content generated. Review the preview below, then release or regenerate.</div>{% endif %}
{% if released %}<div class="alert alert-success">Post released to social platforms.</div>{% endif %}
{% if regenerated %}<div class="alert alert-success">Post regenerated. Review the new preview below.</div>{% endif %}
{% if action_error %}
<div class="alert alert-danger">
    {{ action_error }}
    {% if active_task_id %}<a href="/tasks/{{ active_task_id }}" class="alert-link ms-1">View running task</a>{% endif %}
</div>
{% endif %}

{% if awaiting_review %}
<div class="card border-primary mb-4">
    <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h2 class="h6 mb-1">Awaiting your review</h2>
            <p class="small text-muted mb-0">Preview the copy below. Publish when ready{% if profile and profile.generate_post_image %}, or regenerate the image{% endif %}.</p>
        </div>
        <div class="d-flex gap-2">
            {% if profile and profile.generate_post_image %}
            {% set has_content = post.content_facebook|default(post.content_linkedin)|default('')|trim %}
            {% if has_content %}
            <form method="post" action="/posts/{{ post.id }}/regenerate-image" class="d-inline"
                  onsubmit="return confirm('Regenerate the image for this post? The text will stay the same.');">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-outline-secondary">Regenerate image</button>
            </form>
            {% endif %}
            {% endif %}
            <form method="post" action="/posts/{{ post.id }}/publish" class="d-inline"
                  onsubmit="return confirm('Publish this post to Facebook and LinkedIn now?');">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="btn btn-primary">Publish</button>
            </form>
        </div>
    </div>
</div>
{% endif %}

{% if post.image_path %}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h6">Generated image</h2>
        <img src="/posts/{{ post.id }}/image" alt="Post image" class="img-fluid rounded border" style="max-height: 400px;">
    </div>
</div>
{% elseif profile and profile.generate_post_image and post.image_error %}
<div class="alert alert-warning">Image generation failed: {{ post.image_error }}</div>
{% elseif profile and profile.generate_post_image and post.status in ['ready', 'partial', 'published'] %}
<div class="alert alert-warning">No image was generated for this post.</div>
{% endif %}

<div class="card card-body">
    <h2 class="h6">Post preview</h2>
    <p class="small text-muted mb-2">Same content is published to Facebook and LinkedIn.</p>
    <div class="border rounded p-3 bg-white small" style="white-space: pre-wrap;">{{ post.content_facebook|default(post.content_linkedin)|default('—') }}</div>
</div>

<div class="card mt-4">
    <div class="card-header">Publications</div>
    <ul class="list-group list-group-flush">
        {% for pub in publications %}
        <li class="list-group-item">
            <strong>{{ pub.platform }}</strong> · {{ pub.role }} · {{ pub.display_name }} — {{ pub.status }}
            {% if pub.error_message %}<div class="text-danger small">{{ pub.error_message }}</div>{% endif %}
            {% if pub.external_post_url %}<div class="small"><a href="{{ pub.external_post_url }}" target="_blank">Post link</a></div>{% endif %}
        </li>
        {% else %}
        <li class="list-group-item text-muted">No publications yet.</li>
        {% endfor %}
    </ul>
</div>

{% if post.ai_error %}
<div class="alert alert-danger mt-3">{{ post.ai_error }}</div>
{% endif %}

<a href="/posts" class="btn btn-link mt-3">← Back to posts</a>
<form method="post" action="/posts/{{ post.id }}/delete" class="d-inline mt-3"
      onsubmit="return confirm('Delete this post? This cannot be undone.');">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <button type="submit" class="btn btn-outline-danger btn-sm">Delete post</button>
</form>
{% endblock %}
