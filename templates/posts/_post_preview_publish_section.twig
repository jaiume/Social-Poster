        {% set publish_allowed = 'post' in actions or 'repost' in actions %}
        {% if publish_allowed and publish_accounts is empty %}
        <p class="small text-muted mb-3">No posting accounts configured for this profile.</p>
        {% elseif publish_accounts is not empty %}
        {% set visible_post_account_ids = [] %}
        {% set pending_repost_account_ids = [] %}
        {% for g in publish_accounts %}
            {% if g.primary.show_button %}
                {% set visible_post_account_ids = visible_post_account_ids|merge([g.primary.account.id]) %}
            {% endif %}
            {% if g.show_reposts %}
                {% for r in g.reposts %}
                    {% if not r.done and r.has_session and 'repost' in actions %}
                        {% set pending_repost_account_ids = pending_repost_account_ids|merge([r.account.id]) %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endfor %}
        {% set all_pending_account_ids = visible_post_account_ids|merge(pending_repost_account_ids) %}
        <div class="card card-body p-3 mb-3" id="publish-accounts">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small fw-semibold">Publish accounts</div>
                <div class="d-flex gap-1">
                {% if all_pending_account_ids is not empty %}
                <form method="post" action="/posts/{{ selected_post.id }}/post"
                      onsubmit="return confirm('Publish to {{ all_pending_account_ids|length }} account(s)?');">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="publish_mode" value="all">
                    {% for aid in all_pending_account_ids %}
                        <input type="hidden" name="account_ids[]" value="{{ aid }}">
                    {% endfor %}
                    <button type="submit" class="btn btn-sm btn-success">Post all</button>
                </form>
                {% endif %}
                </div>
            </div>
            {% for g in publish_accounts %}
            <div class="mb-2">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small">
                        <strong>{{ g.platform|capitalize }}</strong>
                        {% if g.primary.not_configured|default(false) %}
                        <span class="text-muted">— Posting account not set</span>
                        {% else %}
                        — {{ g.primary.account.display_name }}
                        <span class="text-muted">({{ g.primary.account.account_kind }})</span>
                        {% endif %}
                    </span>
                    {% if g.primary.not_configured|default(false) %}
                    <button type="button" class="btn btn-sm btn-primary" disabled title="Set a posting account in profile settings">Post</button>
                    {% elseif g.primary.show_button %}
                    <form method="post" action="/posts/{{ selected_post.id }}/post"
                          onsubmit="return confirm('Post to {{ g.primary.account.platform|capitalize }} ({{ g.primary.account.display_name }})?');">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="hidden" name="account_ids[]" value="{{ g.primary.account.id }}">
                        <button type="submit" class="btn btn-sm btn-primary">Post</button>
                    </form>
                    {% elseif g.primary.done %}
                    <span class="badge text-bg-success">Done</span>
                    {% else %}
                    <button type="button" class="btn btn-sm btn-primary" disabled>Post</button>
                    {% endif %}
                </div>
                {% if g.show_reposts %}
                <div class="ps-3 mt-1 border-start">
                    {% for r in g.reposts %}
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <span class="small text-muted">
                            <strong>{{ r.account.platform|capitalize }}</strong> — {{ r.account.display_name }}
                            <span class="text-muted">({{ r.account.account_kind }})</span>
                        </span>
                        {% if r.show_button %}
                        <form method="post" action="/posts/{{ selected_post.id }}/repost"
                              onsubmit="return confirm('Repost to {{ r.account.platform|capitalize }} ({{ r.account.display_name }})?');">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                            <input type="hidden" name="account_ids[]" value="{{ r.account.id }}">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Repost</button>
                        </form>
                        {% elseif r.done %}
                        <span class="badge text-bg-success">Done</span>
                        {% elseif r.locked %}
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled
                                title="Post to the primary account first">Repost</button>
                        {% else %}
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled>Repost</button>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if publication_history is not empty %}
        <div class="card mobile-break-text">
            <div class="card-header py-2 small fw-semibold">Publication history</div>
            <div class="list-group list-group-flush">
                {% for group in publication_history %}
                <div class="list-group-item">
                    <div class="small fw-semibold">{{ group.account.platform }} · {{ group.account.account_kind }} · {{ group.account.display_name }}</div>
                    {% for attempt in group.attempts %}
                    <div class="small mt-1 ps-2 border-start">
                        <span class="badge text-bg-{{ attempt.status == 'success' ? 'success' : (attempt.status == 'failed' ? 'danger' : 'secondary') }}">{{ attempt.status }}</span>
                        {% if attempt.publish_batch_id %}<span class="text-muted">batch {{ attempt.publish_batch_id }}</span>{% endif %}
                        {% if attempt.completed_at %}<span class="text-muted">{{ attempt.completed_at }}</span>{% endif %}
                        {% if attempt.external_post_url %}<div><a href="{{ attempt.external_post_url }}" target="_blank">View post</a></div>{% endif %}
                        {% if attempt.error_message %}<div class="text-danger">{{ attempt.error_message }}</div>{% endif %}
                    </div>
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
