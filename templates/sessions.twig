{% extends "layout_app.twig" %}

{% block title %}Sessions — {{ app_name }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">Browser sessions</h1>

<div class="alert alert-info d-md-none">
    Creating sessions and browser login require a desktop browser.
</div>

{% if imported %}<div class="alert alert-success">Session imported.</div>{% endif %}
{% if deleted %}<div class="alert alert-success">Session deleted.</div>{% endif %}
{% if saved %}<div class="alert alert-success">Saved.</div>{% endif %}
{% if error == 'create' %}<div class="alert alert-danger">Could not create session. Check the name is unique.</div>{% endif %}
{% if error == 'import' %}<div class="alert alert-danger">Import failed. Check JSON format and session selection.</div>{% endif %}
{% if error == 'delete' %}<div class="alert alert-danger">Could not delete session.</div>{% endif %}
{% if error == 'in_use' %}<div class="alert alert-danger">Session is assigned to a profile and cannot be deleted.</div>{% endif %}
{% if error == 'sub_save' %}<div class="alert alert-danger">Could not save sub-page.</div>{% endif %}
{% if error == 'sub_in_use' %}<div class="alert alert-danger">Sub-page is assigned to a profile and cannot be deleted.</div>{% endif %}
{% if error == 'sub_delete' %}<div class="alert alert-danger">Could not delete sub-page.</div>{% endif %}
{% if error == 'rename' %}<div class="alert alert-danger">Could not rename session. Check the name is unique.</div>{% endif %}
{% if error == 'mobile' %}<div class="alert alert-warning">Session create and login are not available on mobile. Use a desktop browser.</div>{% endif %}

<div class="alert alert-warning">
    Browser automation may violate Facebook/LinkedIn terms. Use dedicated accounts.
</div>
<div class="alert alert-info">
    <strong>2FA (authenticator app):</strong> After entering your password, complete the authenticator step in the login window and wait until you see your home feed.
    For Facebook, also click <strong>Continue</strong> on your profile if the account picker appears.
    Sessions only work when capture and posting use the same browser fingerprint — re-login here after any security prompt.
</div>

<div class="card card-body mb-4 d-none d-md-block">
    <h2 class="h6 mb-3">Add session</h2>
    <form method="post" action="/sessions" class="row g-2 align-items-end">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="col-md-5">
            <label class="form-label small">Name</label>
            <input type="text" name="name" class="form-control" placeholder="e.g. Jamie Facebook" required>
        </div>
        <div class="col-md-3">
            <label class="form-label small">Platform</label>
            <select name="platform" class="form-select" required>
                <option value="facebook">Facebook</option>
                <option value="linkedin">LinkedIn</option>
            </select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary">Create and log in</button>
        </div>
    </form>
</div>

{% for platform, platform_sessions in sessions_by_platform %}
<div class="mb-4">
    <h2 class="h5 mb-3">{{ platform|capitalize }}</h2>
    {% if platform_sessions %}
    <div class="row g-3">
        {% for session in platform_sessions %}
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <form method="post" action="/sessions/{{ session.id }}/rename" class="d-flex gap-1 mb-2">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="text" name="name" class="form-control form-control-sm" value="{{ session.name }}" required>
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Rename</button>
                    </form>
                    <p class="mb-1">Status:
                        <span class="badge text-bg-{{ session.status == 'active' ? 'success' : (session.status == 'pending' ? 'warning' : 'secondary') }}">
                            {{ session.status }}
                        </span>
                    </p>
                    <p class="small text-muted mb-1">Last verified: {{ session.last_verified_at|default('—') }}</p>
                    <p class="small text-muted mb-1">Used by {{ session.target_count|default(0) }} profile assignment(s)</p>
                    {% if session.accounts|default([])|length > 0 %}
                    <div class="mt-2 mb-2">
                        <div class="small fw-semibold mb-1">Accounts</div>
                        <ul class="list-unstyled small mb-2">
                            {% for acc in session.accounts %}
                            <li class="mb-1">
                                {% if acc.account_kind == 'root' %}
                                <span class="text-muted">{{ acc.display_name }} (root)</span>
                                {% else %}
                                <span>{{ acc.display_name }}</span>
                                <span class="text-muted">· {{ acc.sub_page_id }}</span>
                                <form method="post" action="/sessions/{{ session.id }}/sub-accounts/{{ acc.id }}/delete" class="d-inline ms-1"
                                      onsubmit="return confirm('Delete sub-page {{ acc.display_name|e('js') }}?');">
                                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Delete</button>
                                </form>
                                {% endif %}
                            </li>
                            {% endfor %}
                        </ul>
                        <form method="post" action="/sessions/{{ session.id }}/sub-accounts" class="row g-1">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                            <div class="col-5">
                                <input type="text" name="display_name" class="form-control form-control-sm" placeholder="Page name" required>
                            </div>
                            <div class="col-5">
                                <input type="text" name="sub_page_id" class="form-control form-control-sm"
                                       placeholder="{{ session.platform == 'linkedin' ? 'company/ID or URL' : 'ID or username' }}" required>
                            </div>
                            <div class="col-2">
                                <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Add</button>
                            </div>
                        </form>
                        {% if session.platform == 'linkedin' %}
                        <p class="small text-muted mb-0 mt-1">Company or showcase admin URL, or <code>company/20107831</code> / <code>showcase/113183993</code>.</p>
                        {% else %}
                        <p class="small text-muted mb-0 mt-1">Page ID (e.g. 61565395796965), username (e.g. WiFiVentures), or full Facebook page URL.</p>
                        {% endif %}
                    </div>
                    {% endif %}
                    {% if session.last_error %}<p class="small text-danger">{{ session.last_error }}</p>{% endif %}
                    <div class="d-flex gap-2 mt-auto pt-2">
                        <button type="button" class="btn btn-sm btn-primary d-none d-md-inline-block" onclick="openCapture({{ session.id }})">
                            {{ session.status == 'active' ? 'Re-login' : 'Log in' }}
                        </button>
                        <form method="post" action="/sessions/{{ session.id }}/delete" class="d-inline"
                              onsubmit="return confirm({{ session.target_count|default(0) > 0
                                  ? ('\'Delete this session? ' ~ session.target_count ~ ' profile assignment(s) must be removed first.\'')
                                  : '\'Delete this session?\'' }});">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <p class="text-muted small">No {{ platform }} sessions yet.</p>
    {% endif %}
</div>
{% endfor %}

<details class="card card-body d-none d-md-block">
    <summary class="h5 mb-0" style="cursor:pointer">Advanced: import storageState JSON manually</summary>
    <p class="small text-muted mt-2 mb-3">Use this if the browser login window is unavailable.</p>
    <form method="post" action="/sessions/import" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="mb-3">
            <label class="form-label">Session</label>
            <select name="session_id" class="form-select" required>
                <option value="">Select session…</option>
                {% for session in sessions %}
                <option value="{{ session.id }}">{{ session.name }} ({{ session.platform }})</option>
                {% endfor %}
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">storageState JSON (paste)</label>
            <textarea name="storage_state" class="form-control font-monospace" rows="6"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Or upload file</label>
            <input type="file" name="storage_file" class="form-control" accept=".json">
        </div>
        <button type="submit" class="btn btn-secondary">Import</button>
    </form>
</details>
{% endblock %}

{% block scripts %}
<script>
function openCapture(sessionId) {
    const w = 720;
    const h = 820;
    const left = Math.max(0, (screen.width - w) / 2);
    const top = Math.max(0, (screen.height - h) / 2);
    window.open(
        '/sessions/capture/' + sessionId,
        'capture_session_' + sessionId,
        'width=' + w + ',height=' + h + ',left=' + left + ',top=' + top + ',resizable=yes,scrollbars=yes'
    );
}
</script>
{% endblock %}
