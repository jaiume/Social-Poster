{% extends "layout_app.twig" %}
{% set csrf_token = csrf_token|default('') %}

{% block title %}Task — {{ app_name }}{% endblock %}

{% block body %}
<h1 class="h3 mb-3">Task progress</h1>
<p class="text-muted small mb-3">Recipe: <code>{{ job.recipe }}</code> · Status: <span id="job-status">{{ job.status }}</span></p>

{% if job.error_message %}
<div class="alert alert-danger">{{ job.error_message }}</div>
{% endif %}

<ul class="list-group mb-4" id="step-list">
    {% for step in job.steps %}
    <li class="list-group-item d-flex justify-content-between align-items-center step-item" data-status="{{ step.status }}">
        <span>{{ step.label }}</span>
        <span class="badge text-bg-secondary step-badge">{{ step.status }}</span>
    </li>
    {% endfor %}
</ul>

<div id="cancel-actions" class="{% if job.status not in ['pending', 'running'] %}d-none{% endif %} mb-3">
    <button type="button" id="cancel-btn" class="btn btn-outline-danger btn-sm">Cancel task</button>
</div>

<div id="completion-actions" class="d-none">
    {% if job.recipe in ['generate_post', 'regenerate_post'] and job.post_id %}
    <a href="/posts?post={{ job.post_id }}" class="btn btn-primary">View post</a>
    {% elseif job.recipe == 'publish_post' and job.post_id %}
    <a href="/posts?post={{ job.post_id }}" class="btn btn-primary">Back to workspace</a>
    {% endif %}
    <a href="/posts" class="btn btn-outline-secondary ms-2">Back to workspace</a>
</div>

<p class="text-muted small" id="poll-hint">Updating…</p>
{% endblock %}

{% block scripts %}
<script>
const jobId = {{ job_id|json_encode|raw }};
const recipe = {{ job.recipe|json_encode|raw }};
const csrfToken = {{ csrf_token|json_encode|raw }};
const reviewRecipes = ['generate_post', 'regenerate_post'];
const publishRecipes = ['publish_post'];
let pollTimer = null;
let lastStatus = {{ job.status|json_encode|raw }};

function completionHint(status) {
    if (status !== 'completed') return 'Task failed.';
    if (publishRecipes.includes(recipe)) return 'Done. Post published.';
    if (reviewRecipes.includes(recipe)) return 'Done. Review your post.';
    return 'Done.';
}

function badgeClass(status) {
    if (status === 'completed') return 'text-bg-success';
    if (status === 'running') return 'text-bg-primary';
    if (status === 'failed') return 'text-bg-danger';
    return 'text-bg-secondary';
}

async function poll() {
    const res = await fetch('/tasks/' + jobId + '/status');
    const data = await res.json();
    if (!data.success) return;

    const info = data.data;
    lastStatus = info.status;
    document.getElementById('job-status').textContent = info.status;

    const items = document.querySelectorAll('.step-item');
    (info.steps || []).forEach((step, i) => {
        const li = items[i];
        if (!li) return;
        li.dataset.status = step.status;
        const badge = li.querySelector('.step-badge');
        badge.textContent = step.status;
        badge.className = 'badge step-badge ' + badgeClass(step.status);
    });

    if (info.status === 'completed' || info.status === 'failed') {
        clearInterval(pollTimer);
        document.getElementById('poll-hint').textContent = completionHint(info.status);
        document.getElementById('cancel-actions')?.classList.add('d-none');
        if (info.status === 'failed' && info.error_message) {
            let alert = document.getElementById('job-error');
            if (!alert) {
                alert = document.createElement('div');
                alert.id = 'job-error';
                alert.className = 'alert alert-danger';
                document.querySelector('h1').after(alert);
            }
            alert.textContent = info.error_message;
        }
        if (info.status === 'completed') {
            document.getElementById('completion-actions').classList.remove('d-none');
            const btn = document.querySelector('#completion-actions .btn-primary');
            if (btn && info.post_id) {
                btn.href = '/posts?post=' + info.post_id;
                btn.textContent = publishRecipes.includes(recipe) ? 'Back to workspace' : 'View post';
            }
        }
    } else if (info.status === 'pending' || info.status === 'running') {
        document.getElementById('cancel-actions')?.classList.remove('d-none');
    }
}

async function parseJsonResponse(res) {
    const text = await res.text();
    try {
        return JSON.parse(text);
    } catch {
        return { success: false, message: text || ('Request failed (' + res.status + ').') };
    }
}

async function cancelJob() {
    if (!confirm('Cancel this task? You can start a new one afterwards.')) return;
    const res = await fetch('/tasks/' + jobId + '/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'csrf_token=' + encodeURIComponent(csrfToken),
    });
    const data = await parseJsonResponse(res);
    if (data.success) {
        clearInterval(pollTimer);
        lastStatus = 'failed';
        document.getElementById('job-status').textContent = 'failed';
        document.getElementById('poll-hint').textContent = 'Task cancelled.';
        document.getElementById('cancel-actions')?.classList.add('d-none');
        await poll();
    } else {
        alert(data.message || 'Could not cancel task.');
    }
}

document.getElementById('cancel-btn')?.addEventListener('click', cancelJob);

function init() {
    pollTimer = setInterval(poll, 1500);
    poll();

    fetch('/tasks/' + jobId + '/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'csrf_token=' + encodeURIComponent(csrfToken),
    }).then(parseJsonResponse).then((start) => {
        if (!start.success && (start.error?.code ?? '') !== 'TASK_ALREADY_RUNNING') {
            document.getElementById('poll-hint').textContent = start.message || 'Could not start task.';
        }
    });
}

init();
</script>
{% endblock %}
